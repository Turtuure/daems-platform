includes:
    - phpstan-baseline.neon

parameters:
    level: 9
    paths:
        - src
        - ../modules/insights/backend/src
        - ../modules/forum/backend/src
        - ../modules/members/backend/src
        - ../modules/projects/backend/src
        - ../modules/events/backend/src
    phpVersion: 80100
    ignoreErrors:
        -
            identifier: missingType.iterableValue
