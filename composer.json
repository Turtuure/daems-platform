{
  "name": "daems/platform",
  "description": "Backend framework for Daems projects (Clean Architecture, REST API, multilingual)",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "Daems\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Daems\\Tests\\": "tests/",
      "DaemsModule\\Insights\\": "../modules/insights/backend/src/",
      "DaemsModule\\Insights\\Tests\\": "../modules/insights/backend/tests/",
      "DaemsModule\\Forum\\": "../modules/forum/backend/src/",
      "DaemsModule\\Forum\\Tests\\": "../modules/forum/backend/tests/",
      "DaemsModule\\Members\\": "../modules/members/backend/src/",
      "DaemsModule\\Members\\Tests\\": "../modules/members/backend/tests/",
      "DaemsModule\\Projects\\": "../modules/projects/backend/src/",
      "DaemsModule\\Projects\\Tests\\": "../modules/projects/backend/tests/",
      "DaemsModule\\Events\\": "../modules/events/backend/src/",
      "DaemsModule\\Events\\Tests\\": "../modules/events/backend/tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^2.0",
    "infection/infection": "^0.29"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --testsuite=Unit,Integration",
    "test:e2e": "vendor/bin/phpunit --testsuite=E2E",
    "test:all": "vendor/bin/phpunit",
    "test:mutation": "vendor/bin/infection --threads=4",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    },
    "platform": {
      "php": "8.1.99"
    }
  }
}
