{
  "name": "daems/platform",
  "description": "Backend framework for Daems projects (Clean Architecture, REST API, multilingual)",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "Daems\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Daems\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "infection/infection": "^0.29"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --testsuite=Unit,Integration",
    "test:e2e": "vendor/bin/phpunit --testsuite=E2E",
    "test:all": "vendor/bin/phpunit",
    "test:mutation": "vendor/bin/infection --threads=4",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    },
    "platform": {
      "php": "8.1.99"
    }
  }
}
